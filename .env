# QuantEdge environment configuration
# Fill in values, then restart app/server.

# --- AI provider ---
# Supported: groq, anthropic
AI_PROVIDER=groq

# --- AI (Groq) ---
GROQ_API_KEY="AddKey"
GROQ_MODEL=llama-3.3-70b-versatile

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional AI controls
AI_MIN_SCORE_THRESHOLD=10

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN= 
TELEGRAM_CHAT_ID=
